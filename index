            <!-- Modal Header -->
            <div class="p-6 border-b border-slate-800 flex justify-between items-center bg-[#111]">
                <div>
                    <div class="text-xs font-bold text-slate-500 tracking-widest uppercase mb-1">Mã Lệnh Kích Hoạt</div>
