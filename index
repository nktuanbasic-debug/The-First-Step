    <!-- Interface Script -->
    <script>
        const apiKey = ""; // API Key được môi trường cấp phát tại runtime
        let currentActiveCardId = 1;

        // 1. Setup Card Flipping for all cards
        document.querySelectorAll('.flashcard').forEach(card => {
            card.addEventListener('click', function() {
                this.classList.toggle('is-flipped');
            });
        });

        // 2. Setup Deck Navigation Logic
        function switchCard(cardId) {
            currentActiveCardId = cardId;
            // Update Buttons
            document.querySelectorAll('.nav-btn').forEach((btn, index) => {
                if (index + 1 === cardId) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });

            // Update Left View (The 3D Card)
            document.querySelectorAll('.view-section').forEach(view => {
                view.classList.remove('active');
            });
            document.getElementById(`card-view-${cardId}`).classList.add('active');

            // Update Right View (The Rulebook)
            document.querySelectorAll('.rulebook-section').forEach(view => {
                view.classList.remove('active');
            });
            document.getElementById(`rulebook-${cardId}`).classList.add('active');

            // Update Sticky Header ID dynamically
            document.getElementById('header-card-id').innerText = cardId === 1 ? '#01' : '#02';
            
            // Adjust header color based on theme
            if(cardId === 1) {
                document.getElementById('header-card-id').className = "grimoire-heading text-3xl font-bold text-red-600";
            } else {
                document.getElementById('header-card-id').className = "grimoire-heading text-3xl font-bold text-purple-600";
            }

            // Scroll Rulebook back to top smoothly
            document.querySelector('.overflow-y-auto').scrollTo({ top: 0, behavior: 'smooth' });
            
            // Make sure the new card starts facing front
            document.querySelectorAll('.flashcard').forEach(card => {
                card.classList.remove('is-flipped');
            });
        }

        // ---------------- AI MODAL LOGIC ----------------
        
        function openAIModal() {
            document.getElementById('ai-modal').classList.add('active');
            document.getElementById('ai-response-area').classList.add('hidden');
            document.getElementById('ai-input').value = '';
            document.getElementById('ai-input').focus();
            
            // Cập nhật tiêu đề theo thẻ đang mở
            const titleElement = document.getElementById('ai-response-title');
            if (currentActiveCardId === 1) {
                titleElement.innerText = "Góc nhìn từ KẺ CÒN SÓT LẠI (#01)";
                titleElement.className = "text-red-500 font-bold tracking-widest uppercase text-sm";
            } else {
                titleElement.innerText = "Góc nhìn từ THUYẾT BÙ TRỪ (#02)";
                titleElement.className = "text-purple-500 font-bold tracking-widest uppercase text-sm";
            }
        }

        function closeAIModal() {
            document.getElementById('ai-modal').classList.remove('active');
        }

        // Đóng modal khi click ra ngoài
        document.getElementById('ai-modal').addEventListener('click', function(e) {
            if (e.target === this) closeAIModal();
        });

        // Parse markdown cơ bản (in đậm, danh sách)
        function parseMarkdown(text) {
            let html = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
            html = html.replace(/^- (.*)$/gm, '<ul><li>$1</li></ul>');
            html = html.replace(/<\/ul>\n<ul>/g, '\n'); // Gộp các thẻ ul liền kề
            html = html.replace(/\n\n/g, '</p><p>');
            return '<p>' + html + '</p>';
        }

        // Hàm delay cho cơ chế retry
        const delay = (ms) => new Promise(res => setTimeout(res, ms));

        // Hàm gọi API Gemini tích hợp Exponential Backoff
        async function generateAIAdvice() {
            const inputField = document.getElementById('ai-input');
            const userProblem = inputField.value.trim();
            
            if (!userProblem) return;

            const submitBtn = document.getElementById('ai-submit-btn');
            const responseArea = document.getElementById('ai-response-area');
            const loadingIndicator = document.getElementById('ai-loading');
            const resultText = document.getElementById('ai-result-text');
            const errorArea = document.getElementById('ai-error');

            // Set Loading State
            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.5';
            responseArea.classList.remove('hidden');
            loadingIndicator.classList.flex = 'flex';
            loadingIndicator.classList.remove('hidden');
            resultText.innerHTML = '';
            errorArea.classList.add('hidden');

            // Thiết lập Prompt dựa trên thẻ đang mở
            const cardContexts = {
                1: "Tên triết lý: Kẻ Còn Sót Lại (He Who Remains). Bản chất: Đứng trước sự sụp đổ của một mớ hỗn độn, hãy chọn ra một điểm cốt lõi duy nhất (Dòng Thời Gian Thiêng Liêng) để giữ lại và nhẫn tâm cắt bỏ (prune) tất cả những thứ rườm rà, cảm xúc, thể diện, hay những ý tưởng hạng hai khác.",
                2: "Tên triết lý: Thuyết Bù Trừ. Bản chất: Khi đã máu lạnh vứt bỏ giá trị A để cứu lấy giá trị cốt lõi B, hệ thống bị thâm hụt. Bạn bắt buộc phải dồn 100% năng lượng siêu việt để đẩy điểm neo B phát triển đến mức cực đại, biến nó thành kiệt tác để bù đắp cho khoảng trống đã mất."
            };

            const systemPrompt = `Bạn là một Cố vấn Chiến lược máu lạnh, thông thái, đang áp dụng giao thức "The First Step" để giải quyết vấn đề. Bạn KHÔNG động viên sáo rỗng. Bạn phân tích vấn đề của người dùng một cách tàn nhẫn và sắc bén, trực tiếp dựa trên triết lý sau đây:\n\n${cardContexts[currentActiveCardId]}\n\nHãy chỉ ra đúng "Điểm neo cốt lõi" cần giữ và "Thứ cần cắt bỏ" (Nếu là thẻ #01), hoặc "Cách đẩy điểm neo lên cực đại" (Nếu là thẻ #02). Trả lời ngắn gọn, đánh trúng tâm lý, bằng tiếng Việt.`;

            const payload = {
                contents: [{ parts: [{ text: `Vấn đề thực tại của tôi là: ${userProblem}\n\nHãy áp dụng triết lý đang mở để cho tôi giải pháp hành động dứt khoát nhất.` }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };

            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const retries = [1000, 2000, 4000, 8000, 16000];
            let success = false;

            for (let i = 0; i <= retries.length; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP Error: ${response.status}`);
                    }

                    const data = await response.json();
                    const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
                    
                    if (text) {
                        loadingIndicator.classList.add('hidden');
                        resultText.innerHTML = parseMarkdown(text);
                        success = true;
                        break; // Thoát vòng lặp retry nếu thành công
                    } else {
                        throw new Error("Không lấy được dữ liệu phản hồi.");
                    }

                } catch (error) {
                    if (i < retries.length) {
                        await delay(retries[i]); // Exponential backoff
                    } else {
                        // Thất bại sau mọi nỗ lực
                        loadingIndicator.classList.add('hidden');
                        errorArea.classList.remove('hidden');
                        errorArea.innerText = "Hệ thống Lãnh Địa tạm thời mất kết nối. Xin hãy thử lại sau.";
                        console.error("Gemini API Error:", error);
                    }
                }
            }

            // Restore Button State
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
        }
    </script>
