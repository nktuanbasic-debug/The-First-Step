<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Tra Cứu: The First Step</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800&family=Montserrat:wght@400;500;700;800&family=Noto+Serif+JP:wght@600;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        /* ---------------- CSS SETUP & SCROLLBAR ---------------- */
        * { box-sizing: border-box; }
        
        body {
            background-color: #050505;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(30, 10, 10, 0.5) 0%, transparent 50%),
                radial-gradient(circle at 85% 30%, rgba(20, 20, 20, 0.8) 0%, transparent 50%),
                linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
            background-size: 100% 100%, 100% 100%, 40px 40px, 40px 40px;
            font-family: 'Inter', sans-serif;
            color: #e2e8f0;
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #111; border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #555; }

        /* ---------------- 3D CARD CSS (LEFT PANEL) ---------------- */
        .card-container {
            perspective: 1500px;
            width: 360px;
            height: 522px;
            cursor: pointer;
            flex-shrink: 0;
            filter: drop-shadow(0 20px 30px rgba(0,0,0,0.8));
        }

        .card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            text-align: left;
            transition: transform 0.8s cubic-bezier(0.4, 0.2, 0.2, 1);
            transform-style: preserve-3d;
        }

        .card-container.is-flipped .card-inner { transform: rotateY(180deg); }

        .card-face {
            position: absolute; width: 100%; height: 100%; backface-visibility: hidden;
            border-radius: 8px; box-shadow: inset 0 0 0 6px #1a1a1a, inset 0 0 0 8px #444;
            padding: 12px; display: flex; flex-direction: column; border: 2px solid #000;
        }

        /* Card Elements */
        .title-box {
            border: 2px solid #333; background: linear-gradient(to bottom, #f4e8c1 0%, #d4b572 100%);
            box-shadow: inset 0 0 4px rgba(255,255,255,0.8), 0 2px 4px rgba(0,0,0,0.5);
            padding: 5px 8px; border-radius: 2px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;
        }
        .card-title { font-family: 'Cinzel', serif; font-size: 19px; font-weight: 800; color: #111; letter-spacing: 1px; text-shadow: 1px 1px 0px rgba(255,255,255,0.5); margin: 0; }
        .attribute-icon { width: 26px; height: 26px; background-color: #555; border-radius: 50%; border: 2px solid #222; display: flex; justify-content: center; align-items: center; font-family: 'Noto Serif JP', serif; font-weight: 900; color: #fff; font-size: 14px; }
        
        .image-box {
            width: 100%; height: 280px; border: 4px solid #333; background-color: #111;
            position: relative; margin-bottom: 10px; display: flex; justify-content: center; align-items: center; overflow: hidden;
        }
        
        .quote-box {
            background: #fdf6e3; border: 2px solid #555; flex-grow: 1; padding: 10px;
            display: flex; align-items: center; justify-content: center; position: relative;
        }
        .quote-box::before { content: ''; position: absolute; top: 2px; left: 2px; right: 2px; bottom: 2px; border: 1px solid rgba(0,0,0,0.1); }
        .quote-text { font-family: 'Noto Serif JP', serif; font-style: italic; font-size: 13px; color: #222; text-align: justify; line-height: 1.4; font-weight: 600; z-index: 1; }

        /* Generic Card Back */
        .card-back {
            transform: rotateY(180deg); border: 4px solid #111; background-color: #3f1515;
            background-image: radial-gradient(circle at center, transparent 30%, #111 80%), repeating-linear-gradient(45deg, #2b0c0c 25%, transparent 25%, transparent 75%, #2b0c0c 75%, #2b0c0c), repeating-linear-gradient(45deg, #2b0c0c 25%, #3f1515 25%, #3f1515 75%, #2b0c0c 75%, #2b0c0c);
            background-position: center center, 0 0, 10px 10px; background-size: 100% 100%, 20px 20px, 20px 20px;
            box-shadow: inset 0 0 15px rgba(0,0,0,0.9), 0 0 20px rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; flex-direction: column;
        }
        .card-back-emblem { width: 160px; height: 160px; border-radius: 50%; border: 6px solid #d4af37; background: #111; display: flex; justify-content: center; align-items: center; box-shadow: 0 0 30px #000, inset 0 0 20px rgba(0,0,0,0.8); position: relative; }
        .card-back-emblem::before { content: ''; position: absolute; width: 120px; height: 120px; border: 2px dashed #d4af37; border-radius: 50%; animation: spin 20s linear infinite; }
        .card-back-emblem-text { font-family: 'Cinzel', serif; font-weight: 800; color: #d4af37; font-size: 24px; text-align: center; line-height: 1.2; z-index: 1; }
        .card-back-emblem-sub { font-family: 'Montserrat', sans-serif; font-size: 9px; letter-spacing: 3px; color: #888; margin-top: 5px; z-index: 1; }
        @keyframes spin { 100% { transform: rotate(360deg); } }

        .flip-hint { position: absolute; bottom: -30px; left: 0; width: 100%; text-align: center; color: #64748b; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; font-family: 'Montserrat', sans-serif; }

        /* ---------------- VIEW SWITCHER CSS ---------------- */
        .view-section { display: none; animation: fadeIn 0.4s ease-in-out; }
        .view-section.active { display: flex; flex-direction: column; width: 100%; height: 100%; justify-content: center; align-items: center; }
        
        .rulebook-section { display: none; animation: fadeIn 0.4s ease-in-out; }
        .rulebook-section.active { display: block; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Selector Navigation */
        .deck-nav {
            display: flex; gap: 10px; margin-top: 40px; width: 100%; justify-content: center; flex-wrap: wrap;
        }
        .nav-btn {
            background: #111; border: 1px solid #333; color: #888; font-family: 'Montserrat', sans-serif;
            font-size: 12px; font-weight: 600; padding: 8px 16px; border-radius: 20px; cursor: pointer;
            transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 1px;
        }
        .nav-btn:hover { border-color: #666; color: #ccc; }
        .nav-btn.active { background: #7f1d1d; border-color: #dc2626; color: #fff; box-shadow: 0 0 10px rgba(220, 38, 38, 0.3); }

        /* Card Color Themes */
        .card-theme-earth { background-color: #c08552; background-image: linear-gradient(135deg, #d3965c 0%, #9e5b22 100%); }
        .card-theme-magic { background-color: #6b21a8; background-image: linear-gradient(135deg, #9333ea 0%, #4c1d95 100%); }

        /* Typography */
        .grimoire-heading { font-family: 'Cinzel', serif; }
        .grimoire-subheading { font-family: 'Montserrat', sans-serif; }

        /* ---------------- AI MODAL CSS ---------------- */
        #ai-modal {
            backdrop-filter: blur(8px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        #ai-modal.active {
            opacity: 1;
            pointer-events: auto;
        }
        .ai-content {
            transform: translateY(20px);
            transition: transform 0.3s ease;
            box-shadow: 0 0 40px rgba(220, 38, 38, 0.15), inset 0 0 0 1px #333;
        }
        #ai-modal.active .ai-content {
            transform: translateY(0);
        }
        .ai-loading-spinner {
            border: 3px solid rgba(255,255,255,0.1);
            border-top-color: #dc2626;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
            display: inline-block;
        }
        .markdown-body strong { color: #f8fafc; font-weight: 700; }
        .markdown-body ul { list-style-type: disc; padding-left: 20px; margin-top: 8px; margin-bottom: 8px; }
        .markdown-body li { margin-bottom: 4px; }
        .markdown-body p { margin-bottom: 12px; }
    </style>
</head>
