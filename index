                    <button id="ai-submit-btn" onclick="generateAIAdvice()" class="flex items-center gap-2 bg-red-900 hover:bg-red-800 text-white px-6 py-3 rounded border border-red-700 transition-colors font-bold tracking-widest uppercase text-sm shadow-[0_0_15px_rgba(220,38,38,0.3)]">
