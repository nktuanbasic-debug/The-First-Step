            <!-- Modal Body -->
            <div class="p-6 overflow-y-auto flex-grow flex flex-col gap-6" id="ai-body-container">
                
                <div class="bg-[#111] border border-slate-800 p-5 rounded-lg relative">
                    <div class="absolute -top-3 left-4 bg-[#0a0a0a] px-2 text-xs font-bold text-slate-400 tracking-widest uppercase">Nhập Vấn Đề Thực Tại</div>
                    <textarea id="ai-input" class="w-full bg-transparent text-slate-200 outline-none resize-none h-24 font-['Inter'] placeholder-slate-600" placeholder="Kẻ thù của bạn là gì? Deadline? Khách hàng? Một mớ hỗn độn không hồi kết?..."></textarea>
                </div>

